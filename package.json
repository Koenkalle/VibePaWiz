{
  "name": "vibepawiz",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Explorative visualization of scientific citation networks. A from-scratch rewrite of SciPaWiz using OpenAlex and Cytoscape.js.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cytoscape": "^3.30.4",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "lz-string": "^1.5.0",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
